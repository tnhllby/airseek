# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airseek:airseek@localhost:5432/airseek

# ─── Collector ───────────────────────────────────────────────
COLLECT_INTERVAL_SECONDS=900

# ─── Sources ─────────────────────────────────────────────────
ENABLE_OPENAQ=true
ENABLE_IQAIR=false
ENABLE_HTTP_SENSORS=false

# OpenAQ (ключ необязателен, но повышает лимиты)
OPENAQ_API_KEY=e6baa39c808c8c5bc0264f870cb23a025e4ef7bf332da0938a2d9a61eb925011
OPENAQ_CITY=Bishkek
OPENAQ_COUNTRY=KG

# IQAir / AirVisual
IQAIR_API_KEY=
IQAIR_CITY=Bishkek
IQAIR_STATE=Bishkek
IQAIR_COUNTRY=Kyrgyzstan

# HTTP Sensors (через запятую)
# HTTP_SENSOR_URLS=http://192.168.1.10,http://192.168.1.11

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
