# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airseek:airseek@db:5432/airseek

# ─── Collector ───────────────────────────────────────────────
COLLECT_INTERVAL_SECONDS=900

# ─── Sources ─────────────────────────────────────────────────
ENABLE_OPENAQ=true
ENABLE_IQAIR=false
ENABLE_HTTP_SENSORS=false

# OpenAQ (key optional, but raises rate limits)
OPENAQ_API_KEY=
OPENAQ_CITY=Bishkek
OPENAQ_COUNTRY=KG

# IQAir / AirVisual
IQAIR_API_KEY=
IQAIR_CITY=Bishkek
IQAIR_STATE=Bishkek
IQAIR_COUNTRY=Kyrgyzstan

# HTTP Sensors (comma-separated)
# HTTP_SENSOR_URLS=

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
