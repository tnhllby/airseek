# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airseek:airseek@localhost:5432/airseek

# ─── Collector ───────────────────────────────────────────────
COLLECT_INTERVAL_SECONDS=900

# ─── Sources ─────────────────────────────────────────────────
ENABLE_OPENAQ=true
ENABLE_IQAIR=false
ENABLE_HTTP_SENSORS=false

# OpenAQ (ключ необязателен, но повышает лимиты)
OPENAQ_API_KEY=
OPENAQ_CITY=Bishkek
OPENAQ_COUNTRY=KG

# IQAir / AirVisual
IQAIR_API_KEY=
IQAIR_CITY=Bishkek
IQAIR_STATE=Bishkek
IQAIR_COUNTRY=Kyrgyzstan

# HTTP Sensors (через запятую)
# HTTP_SENSOR_URLS=http://192.168.1.10,http://192.168.1.11

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Backend ─────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-32-chars-minimum-here
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Provider: gemini | claude | deepseek | ollama
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
DEEPSEEK_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

CORS_ORIGINS=http://localhost:3000,http://localhost:8080
